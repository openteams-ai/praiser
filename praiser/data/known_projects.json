{
  "_schema": "praiser known-projects registry v1",
  "_doc": "Curated popular/important projects with role-defining heuristics and popularity hints. 'role_conventions' tell extractors how each project records roles; 'popularity.min_stars_override' keeps high-signal-but-small standards projects past the popularity filter. The tool may append observed popularity to this structure with --save-registry.",
  "projects": {
    "python/peps": {
      "importance": "critical",
      "role_conventions": [
        {
          "extractor": "enhancement_proposals",
          "role": "standards_author",
          "path": "peps",
          "header_format": "rst"
        }
      ],
      "popularity": { "min_stars_override": true, "contributors": 637 },
      "notes": "Python Enhancement Proposals; RST files pep-NNNN.rst with ':Author:' headers."
    },
    "numpy/numpy": {
      "importance": "critical",
      "role_conventions": [
        {
          "extractor": "enhancement_proposals",
          "role": "standards_author",
          "path": "doc/neps",
          "header_format": "rst"
        },
        { "extractor": "codeowners", "role": "code_owner" }
      ],
      "role_sources": [
        {
          "url": "https://numpy.org/teams/",
          "role": "maintainer",
          "label": "NumPy team page"
        },
        {
          "url": "https://numpy.org/about/",
          "role": "steering_council",
          "label": "NumPy Steering Council"
        }
      ],
      "subcomponents": [
        { "path": "numpy/f2py", "role": "author", "label": "f2py" }
      ],
      "popularity": { "contributors": 2097 },
      "notes": "NEPs under doc/neps (RST); authoritative roles on numpy.org."
    },
    "pytorch/pytorch": {
      "importance": "critical",
      "role_sources": [
        {
          "url": "https://docs.pytorch.org/docs/main/community/persons_of_interest.html",
          "role": "maintainer",
          "label": "PyTorch Persons of Interest"
        }
      ],
      "subcomponents": [
        { "path": "aten/src/ATen/native/sparse", "role": "maintainer", "label": "sparse tensors" },
        { "path": "torch/sparse", "role": "maintainer", "label": "sparse tensors" }
      ],
      "popularity": { "contributors": 6683 },
      "notes": "Module maintainers listed on the Persons of Interest page; the repo also has a CODEOWNERS."
    },
    "scientific-python/specs": {
      "importance": "high",
      "role_conventions": [
        {
          "extractor": "enhancement_proposals",
          "role": "standards_author",
          "path": ".",
          "header_format": "yaml"
        }
      ],
      "popularity": { "min_stars_override": true },
      "notes": "Scientific Python SPECs; Markdown with YAML front-matter 'author:'."
    },
    "jupyter/enhancement-proposals": {
      "importance": "high",
      "role_conventions": [
        {
          "extractor": "enhancement_proposals",
          "role": "standards_author",
          "path": ".",
          "header_format": "yaml"
        }
      ],
      "popularity": { "min_stars_override": true },
      "notes": "Jupyter Enhancement Proposals (JEPs); Markdown with YAML front-matter."
    },
    "kubernetes/kubernetes": {
      "importance": "critical",
      "role_conventions": [
        { "extractor": "maintainers", "role": "maintainer", "path": "OWNERS" }
      ],
      "popularity": { "contributors": 5778 },
      "notes": "Uses Kubernetes OWNERS (YAML) files with approvers/reviewers."
    }
  }
}
